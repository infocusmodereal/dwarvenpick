{
    "name": "dwarvenpick-frontend",
    "version": "0.29.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "test": "vitest run",
        "browser:smoke": "node scripts/run-browser-smoke.mjs",
        "browser:smoke:list": "playwright test --config playwright.config.ts --list",
        "browser:smoke:typecheck": "tsc --project tsconfig.playwright.json"
    },
    "dependencies": {
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@monaco-editor/react": "^4.7.0",
        "@tanstack/react-table": "^8.21.3",
        "monaco-editor": "^0.52.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.30.4",
        "sql-formatter": "^15.6.10"
    },
    "devDependencies": {
        "@eslint/js": "^9.21.0",
        "@playwright/test": "1.61.1",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "22.20.1",
        "@types/react": "^18.3.20",
        "@types/react-dom": "^18.3.6",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.21.0",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^15.15.0",
        "jsdom": "^26.0.0",
        "prettier": "^3.5.3",
        "typescript": "~5.7.2",
        "typescript-eslint": "^8.25.0",
        "vite": "^6.2.0",
        "vitest": "^3.0.7"
    }
}
